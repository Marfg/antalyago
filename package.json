{
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "serve": "npx serve . -p 3000 --no-clipboard",
    "test-core": "node --experimental-vm-modules tests/run.js",
    "test-problems": "node tests/problemBank.test.js && node tests/problemBank-audit.test.js && node tests/problemBank-sources.test.js && node tests/problemBank-candidates.test.js && node tests/problemBank-candidate-studio.test.js && node tests/problemBank-review.test.js && node tests/problemBank-promotion.test.js && node tests/problemBank-migration.test.js",
    "validate-problems": "node scripts/problem-bank/validate.mjs",
    "test-all": "npm run test-core && npm run test-problems && npm run test-learning && npm run test-learning-ui && npm run test-b2 && npm run test-ai && npm run test-robot && npm run test-theme && npm run test-go-nedir && npm run test-studio",
    "test-learning": "node tests/learningContext.test.js",
    "test-learning-ui": "node tests/learning-ui.test.js && node tests/verify-learning-ui.mjs",
    "test-design-system": "node tests/design-system.test.js && node tests/verify-design-system.mjs",
    "audit-curriculum": "node scripts/curriculum/audit.mjs",
    "test-b2": "node tests/b2Assessment.test.js",
    "test-ai": "node tests/goAI.test.js",
    "test-robot": "node tests/verify-robot.mjs",
    "test-theme": "node tests/theme.test.js && node tests/home-content.test.js && npm run test-design-system && node tests/verify-theme.mjs",
    "test-go-nedir": "node tests/go-nedir-content.test.js && node tests/verify-go-nedir.mjs",
    "test-home-content": "node tests/home-content.test.js",
    "benchmark-ai": "node scripts/ai/benchmark.mjs",
    "studio": "electron .",
    "test-studio": "node tests/studio-document.test.js && node tests/studio-text-tree.test.js && node tests/studio-server.test.js && npm run test-studio-electron && node tests/verify-studio-desktop.mjs",
    "test-studio-electron": "node tests/studio-electron.test.js && node tests/studio-candidate-electron.test.js",
    "test-studio-text-tree": "node tests/studio-text-tree.test.js",
    "audit-problem-bank": "node scripts/problem-bank/audit.mjs",
    "migrate-problem-bank": "node scripts/problem-bank/migrate.mjs",
    "audit-problem-sources": "node scripts/problem-bank/audit-sources.mjs",
    "reconcile-problem-sources": "node scripts/problem-bank/reconcile-sources.mjs",
    "verify-local-sources": "node scripts/problem-bank/verify-local-sources.mjs",
    "audit-problem-candidates": "node scripts/problem-bank/audit-candidates.mjs",
    "promote-problem-candidate": "node scripts/problem-bank/promote-candidate.mjs",
    "test-problem-candidates": "node tests/problemBank-candidates.test.js",
    "export-candidate-studio": "node scripts/problem-bank/candidate-to-studio.mjs",
    "test-candidate-studio": "node tests/problemBank-candidate-studio.test.js",
    "review-problem-candidate": "node scripts/problem-bank/review-candidate.mjs",
    "review-problem-candidates": "node scripts/problem-bank/review-candidate.mjs",
    "test-problem-review": "node tests/problemBank-review.test.js && node tests/problemBank-promotion.test.js"
  },
  "devDependencies": {
    "electron": "43.0.0",
    "playwright-core": "^1.59.1"
  }
}
