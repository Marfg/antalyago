{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://antalyago.local/problem-bank/candidate.schema.json",
  "title": "AntalyaGo Problem Bank Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidateId",
    "candidateVersion",
    "status",
    "source",
    "extraction",
    "curriculum",
    "board",
    "task",
    "review",
    "rights"
  ],
  "properties": {
    "candidateId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "candidateVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "extracted",
        "needs-review",
        "rejected",
        "promoted"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "locator",
        "usage"
      ],
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "pdf-page",
                "printed-page",
                "section",
                "unresolved"
              ]
            },
            "value": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "string",
                  "minLength": 1
                }
              ]
            }
          }
        },
        "usage": {
          "type": "string",
          "enum": [
            "concept_reference",
            "editorial_reference",
            "import_reference"
          ]
        }
      }
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "extractedAt",
        "extractor",
        "confidence",
        "notes"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "manual",
            "assisted",
            "ocr",
            "vision",
            "sgf",
            "mixed"
          ]
        },
        "extractedAt": {
          "type": "string",
          "format": "date-time"
        },
        "extractor": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "curriculum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section",
        "lesson",
        "skill",
        "tags"
      ],
      "properties": {
        "section": {
          "type": "string",
          "minLength": 1
        },
        "lesson": {
          "type": "string",
          "minLength": 1
        },
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "board": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "size",
        "initialStones",
        "markers"
      ],
      "properties": {
        "size": {
          "type": "integer",
          "minimum": 5
        },
        "initialStones": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "color",
              "x",
              "y"
            ],
            "properties": {
              "color": {
                "type": "string",
                "enum": [
                  "black",
                  "white"
                ]
              },
              "x": {
                "type": "integer",
                "minimum": 0
              },
              "y": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "markers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "x",
              "y",
              "label"
            ],
            "properties": {
              "x": {
                "type": "integer",
                "minimum": 0
              },
              "y": {
                "type": "integer",
                "minimum": 0
              },
              "label": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "prompt",
        "expectedAnswer",
        "answerPolicy"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "expectedAnswer": {},
        "answerPolicy": {
          "type": "string",
          "minLength": 1
        },
        "answer": {},
        "solution": {
          "type": "string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "reviewer",
        "reviewedAt",
        "checklist"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true,
          "default": true
        },
        "reviewer": {
          "type": [
            "string",
            "null"
          ]
        },
        "reviewedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "checklist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "studio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "compatible": {
          "type": "boolean"
        },
        "documentRef": {
          "type": [
            "string",
            "null"
          ]
        },
        "proposedStudioDocument": {}
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceRightsSnapshot",
        "canPublish",
        "needsRightsReview"
      ],
      "properties": {
        "sourceRightsSnapshot": {
          "type": "object"
        },
        "canPublish": {
          "type": "boolean",
          "const": false,
          "default": false
        },
        "needsRightsReview": {
          "type": "boolean",
          "const": true,
          "default": true
        }
      }
    },
    "pedagogy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "useCase": {
          "type": "string",
          "enum": [
            "intro-card",
            "drill",
            "guided-practice",
            "assessment",
            "worked-example",
            "worked-example-draft",
            "redesign-needed"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "intro",
            "very-easy",
            "easy",
            "medium",
            "hard"
          ]
        },
        "reviewDecision": {
          "type": "string",
          "enum": [
            "keep",
            "revise",
            "redesign",
            "reject"
          ]
        },
        "reviewNotes": {
          "type": "string"
        }
      }
    }
  }
}
